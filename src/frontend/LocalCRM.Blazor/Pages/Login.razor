@page "/login"
@layout LoginLayout
@using MudBlazor
@using LocalCRM.Blazor.Services
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">LocalCRM Login</MudText>
        <MudTextField @bind-Value="_username" Label="Username" Variant="Variant.Outlined" Class="mb-4" />
        <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-6" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="HandleLogin" Disabled="_loading">
            @if (_loading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Logging in...</MudText>
            }
            else
            {
                <MudText>Login</MudText>
            }
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private string _username = "";
    private string _password = "";
    private bool _loading = false;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add("Please enter both username and password.", Severity.Warning);
            return;
        }

        _loading = true;
        var success = await AuthService.Login(_username, _password);
        _loading = false;

        if (success)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            Snackbar.Add("Login failed. Please check your credentials.", Severity.Error);
        }
    }
}
