@page "/settings"
@using MudBlazor
@using LocalCRM.Blazor.Models
@using Microsoft.AspNetCore.Authorization
@inject HttpClient HttpClient
@attribute [Authorize(Roles = "Administrator")]

<PageTitle>System Settings</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">System Settings</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">General Settings</MudText>
            <MudList T="SettingDto">
                @if (_settings == null)
                {
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                }
                else
                {
                    @foreach (var setting in _settings)
                    {
                        <MudListItem>
                            <div class="d-flex align-center">
                                <MudText Typo="Typo.body1" Class="flex-grow-1">@setting.Key</MudText>
                                <MudTextField @bind-Value="setting.Value" Variant="Variant.Outlined" Margin="Margin.Dense" Class="ml-4" Style="max-width: 200px;" />
                            </div>
                        </MudListItem>
                    }
                }
            </MudList>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Save Changes</MudButton>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-4">System Information</MudText>
            <MudField Label="Version" Variant="Variant.Text">1.0.0-scaffold</MudField>
            <MudField Label="Database" Variant="Variant.Text">SQLite</MudField>
            <MudField Label="Environment" Variant="Variant.Text">Development</MudField>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<SettingDto>? _settings;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _settings = await HttpClient.GetFromJsonAsync<List<SettingDto>>("api/settings");
        }
        catch
        {
            _settings = new List<SettingDto>
            {
                new SettingDto { Key = "OrganizationName", Value = "LocalCRM" },
                new SettingDto { Key = "DefaultCurrency", Value = "USD" }
            };
        }
    }
}
