@page "/change-password-required"
@using LocalCRM.Blazor.Auth
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Class="pa-8" Elevation="3">
        <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">Password Change Required</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">You must change your password before continuing.</MudText>

        <MudTextField @bind-Value="newPassword" Label="New Password" Variant="Variant.Outlined" InputType="InputType.Password" Class="mt-4" />
        <MudTextField @bind-Value="confirmPassword" Label="Confirm Password" Variant="Variant.Outlined" InputType="InputType.Password" Class="mt-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-6" OnClick="Submit">Change Password</MudButton>
    </MudPaper>
</MudContainer>

@code {
    [Parameter, SupplyParameterFromQuery] public string? username { get; set; }
    private string newPassword = "";
    private string confirmPassword = "";

    private async Task Submit()
    {
        if (newPassword != confirmPassword) { Snackbar.Add("Passwords do not match.", Severity.Warning); return; }

        var response = await Http.PostAsJsonAsync("api/auth/complete-password-change", new { Username = username, NewPassword = newPassword });
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add("Password changed successfully. Please login with your new password.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add("Failed to change password.", Severity.Error);
        }
    }
}
