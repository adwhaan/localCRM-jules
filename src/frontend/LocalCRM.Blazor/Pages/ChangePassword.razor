@page "/change-password"
@using MudBlazor
@using LocalCRM.Blazor.Services
@inject HttpClient HttpClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Change Password</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">Change Password</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">Please update your password to continue.</MudText>

        <MudTextField @bind-Value="_currentPassword" Label="Current Password" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" />
        <MudTextField @bind-Value="_newPassword" Label="New Password" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" />
        <MudTextField @bind-Value="_confirmPassword" Label="Confirm New Password" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-6" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="HandleChangePassword" Disabled="_loading">
            @if (_loading)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Updating...</MudText>
            }
            else
            {
                <MudText>Update Password</MudText>
            }
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _loading = false;

    private async Task HandleChangePassword()
    {
        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("New passwords do not match.", Severity.Error);
            return;
        }

        _loading = true;
        try
        {
            var response = await HttpClient.PostAsJsonAsync("api/auth/change-password", new { CurrentPassword = _currentPassword, NewPassword = _newPassword });
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Password updated successfully.", Severity.Success);
                NavigationManager.NavigateTo("/");
            }
            else
            {
                Snackbar.Add("Failed to update password.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
